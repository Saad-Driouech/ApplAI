# applai/.env — Copy to .env, fill in values, NEVER commit
# ─────────────────────────────────────────────────────────

# ── n8n Authentication ──
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_use_a_strong_password_here

# ── Gemini API (Tier 1 — scoring, filtering, research) ──
# Get free API key: https://aistudio.google.com/apikey
# Free tier: 1,000 requests/day, 15 RPM — no credit card needed
GOOGLE_AI_API_KEY=

# ── Discord Bot ──
# 1. https://discord.com/developers/applications → New Application → Bot → Reset Token
# 2. OAuth2 → URL Generator → scopes: bot → permissions: Send Messages, Attach Files
# 3. Open the generated URL to invite the bot to your server
# 4. Right-click your channel → Copy Channel ID (enable Developer Mode in Discord settings first)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── Notion Integration ──
# Create at https://www.notion.so/my-integrations
NOTION_API_TOKEN=
NOTION_JOB_TRACKER_DB_ID=
NOTION_FEEDBACK_LOG_DB_ID=

# ── Candidate Info (used in document headers) ──
CANDIDATE_NAME=Your Full Name
CANDIDATE_EMAIL=your@email.com

# ── Paths ──
# Set APPLAI_WORKING_DIR to an absolute path on your host machine
APPLAI_WORKING_DIR=/absolute/path/to/your/job_applications
APPLAI_DB_PATH=/data/db/applai.db
APPLAI_LOGS_DIR=/absolute/path/to/your/job_applications/logs

# Path to your .tex CV template (on the host — mounted into Docker)
APPLAI_CV_TEMPLATE=/absolute/path/to/your/cv.tex

# ── Claude Code (Tier 2 — CV + cover letter) ──
# Auth token is NOT stored here — it lives in Claude's own config dir
# mounted read-only into the container. See docker-compose.yml.
CLAUDE_BINARY=claude
CLAUDE_TIMEOUT=120

# ── Gemini tuning ──
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RPD=500
GEMINI_RPM=15
SCORE_THRESHOLD=6.0

# ── LLM Provider (Tier 1) ──
# "gemini" | "groq" | "ollama"
LLM_TIER1_PROVIDER=gemini

# ── Groq API (alternative to Gemini — higher free-tier limits) ──
# Get free API key: https://console.groq.com/keys
# Free tier: llama-3.3-70b-versatile → 30 RPM, ~14,400 RPD
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_RPM=30
GROQ_RPD=14400

# ── Ollama fallback (uncomment if using local) ──
# OLLAMA_ENABLED=true
# OLLAMA_ENDPOINT=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3:8b

# ── Debug ──
APPLAI_DEBUG=false
